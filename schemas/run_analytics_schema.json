{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Run Analytics Schema",
  "type": "object",
  "required": [
    "run_id",
    "seed",
    "route",
    "ended",
    "victory",
    "end_reason",
    "player_final",
    "decision_log",
    "summary",
    "failure_analysis",
    "run_summary"
  ],
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "seed": { "type": "integer" },
    "route": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "ended": { "type": "boolean" },
    "victory": { "type": "boolean" },
    "end_reason": { "type": ["string", "null"] },
    "player_final": {
      "type": "object",
      "required": ["hp", "food", "ammo", "medkits", "scrap", "radiation"],
      "properties": {
        "hp": { "type": "integer" },
        "food": { "type": "integer" },
        "ammo": { "type": "integer" },
        "medkits": { "type": "integer" },
        "scrap": { "type": "integer" },
        "radiation": { "type": "integer" },
        "weapon_slot": { "type": ["string", "null"] },
        "armor_slot": { "type": ["string", "null"] },
        "tool_slot": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "decision_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["step", "node", "event_id", "option_index", "warning_signals", "pre_choice_state", "pressure", "player_after"],
        "properties": {
          "step": { "type": "integer", "minimum": 1 },
          "node": { "type": "string" },
          "event_id": { "type": "string" },
          "option_index": { "type": "integer", "minimum": 0 },
          "warning_signals": {
            "type": "array",
            "items": { "type": "string" }
          },
          "pre_choice_state": {
            "type": "object",
            "required": ["hp", "food", "ammo", "medkits", "radiation"],
            "properties": {
              "hp": { "type": "integer" },
              "food": { "type": "integer" },
              "ammo": { "type": "integer" },
              "medkits": { "type": "integer" },
              "radiation": { "type": "integer" },
              "weapon_slot": { "type": ["string", "null"] },
              "armor_slot": { "type": ["string", "null"] },
              "tool_slot": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          },
          "pressure": { "type": "boolean" },
          "combat_triggered": { "type": "boolean" },
          "combat_loot": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["resource", "amount"],
              "properties": {
                "resource": { "type": "string", "minLength": 1 },
                "amount": { "type": "integer", "minimum": 1 }
              },
              "additionalProperties": false
            }
          },
          "effects": { "type": "object" },
          "equipment_change": { "type": ["object", "null"] },
          "equipment_summary": { "type": ["string", "null"] },
          "player_after": {
            "type": "object",
            "required": ["hp", "food", "ammo", "medkits", "radiation"],
            "properties": {
              "hp": { "type": "integer" },
              "food": { "type": "integer" },
              "ammo": { "type": "integer" },
              "medkits": { "type": "integer" },
              "radiation": { "type": "integer" },
              "weapon_slot": { "type": ["string", "null"] },
              "armor_slot": { "type": ["string", "null"] },
              "tool_slot": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "object",
      "required": ["pressure_count", "death_cause_attribution", "resource_signature"],
      "properties": {
        "pressure_count": { "type": "integer", "minimum": 0 },
        "death_cause_attribution": { "type": "boolean" },
        "resource_signature": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "failure_analysis": {
      "type": "object",
      "required": ["death_chain_length", "primary_blame_factor", "regret_nodes", "steps_from_regret_to_death", "is_trash_time_death"],
      "properties": {
        "death_chain_length": { "type": "integer", "minimum": 0 },
        "primary_blame_factor": { "type": ["string", "null"] },
        "regret_nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["node_id", "event_id", "blame_score", "description"],
            "properties": {
              "node_id": { "type": "string", "minLength": 1 },
              "event_id": { "type": "string", "minLength": 1 },
              "blame_score": { "type": "number", "minimum": 0, "maximum": 1 },
              "description": { "type": "string", "minLength": 1 },
              "steps_to_death": { "type": "integer", "minimum": 0 }
            },
            "additionalProperties": false
          }
        },
        "steps_from_regret_to_death": { "type": "integer", "minimum": 0 },
        "is_trash_time_death": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "run_summary": {
      "type": "object",
      "required": ["headline", "route_family", "outcome", "key_turning_point", "notable_equipment", "telemetry"],
      "properties": {
        "headline": { "type": "string", "minLength": 1 },
        "route_family": { "type": "string", "minLength": 1 },
        "outcome": { "type": "string", "minLength": 1 },
        "key_turning_point": { "type": ["string", "null"] },
        "notable_equipment": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "telemetry": {
          "type": "object",
          "required": [
            "total_steps",
            "pressure_count",
            "combat_count",
            "loot_drop_count",
            "loot_total_amount",
            "equipment_change_count",
            "equipment_ids",
            "loot_resources",
            "max_radiation",
            "min_food",
            "min_hp",
            "low_resource_flags",
            "risk_tags"
          ],
          "properties": {
            "total_steps": { "type": "integer", "minimum": 0 },
            "pressure_count": { "type": "integer", "minimum": 0 },
            "combat_count": { "type": "integer", "minimum": 0 },
            "loot_drop_count": { "type": "integer", "minimum": 0 },
            "loot_total_amount": { "type": "integer", "minimum": 0 },
            "equipment_change_count": { "type": "integer", "minimum": 0 },
            "equipment_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "loot_resources": {
              "type": "object",
              "additionalProperties": {
                "type": "integer",
                "minimum": 0
              }
            },
            "max_radiation": { "type": "integer", "minimum": 0 },
            "min_food": { "type": "integer", "minimum": 0 },
            "min_hp": { "type": "integer", "minimum": 0 },
            "low_resource_flags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "risk_tags": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
